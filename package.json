{
  "name": "contoso-university",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "npx playwright test",
    "test:e2e": "npx playwright test",
    "test:list": "npx playwright test --list",
    "load:test": "python -m locust -f tests/load/locustfile.py --host=http://127.0.0.1:4173",
    "load:test:coverage": "bash .github/hooks/scripts/load-test-coverage.sh --strict",
    "copilot:audit": "bash scripts/copilot/audit.sh",
    "copilot:docs": "bash scripts/copilot/document.sh",
    "copilot:onboard": "bash scripts/copilot/onboard.sh",
    "copilot:review": "bash scripts/copilot/review-file.sh"
  },
  "dependencies": {
    "@microsoft/applicationinsights-web": "^3.4.1",
    "lucide-react": "^0.574.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
